# Variables for the NEW "n8n-worker" service.
#
# Easiest + safest: in Railway, duplicate the existing n8n service (or create a new service
# from the same source/image), then make sure its variables match the main service EXACTLY
# for everything below, and set the start command to:  n8n worker --concurrency=5
#
# The worker shares the SAME Postgres and the SAME encryption key as main. If either differs,
# the worker cannot read workflows or decrypt credentials and every execution fails.

# --- Must be IDENTICAL to the main service (copy the real values from main) ---
# N8N_ENCRYPTION_KEY  <<< COPY THE EXACT VALUE FROM THE MAIN SERVICE. #1 cause of failures if wrong.
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=...        (same DB as main)
# DB_POSTGRESDB_PORT=...
# DB_POSTGRESDB_DATABASE=...
# DB_POSTGRESDB_USER=...
# DB_POSTGRESDB_PASSWORD=...
# GENERIC_TIMEZONE=...          (same as main, so cron schedules line up)
# (copy any other DB_* / N8N_* the main service defines)

# --- Queue + Redis (same Redis as main) ---
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=${{Redis.RAILWAY_PRIVATE_DOMAIN}}
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=${{Redis.REDISPASSWORD}}
QUEUE_HEALTH_CHECK_ACTIVE=true

# Worker concurrency is set on the start command, not here:
#   Start Command:  n8n worker --concurrency=5
#
# The worker serves no HTTP, so it needs NO public domain and NO N8N_HOST / WEBHOOK_URL / PORT.
# Copying those from main is harmless, but a public domain is unnecessary.
