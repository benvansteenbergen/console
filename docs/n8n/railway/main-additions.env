# ADD these variables to the EXISTING n8n service (the one serving the UI/webhooks).
# Paste into Railway -> n8n service -> Variables -> "Raw Editor".
# Do NOT remove or change the service's existing variables (DB_*, N8N_ENCRYPTION_KEY, etc.).
# After saving, redeploy the service.

# Switch n8n from single-process to queue mode.
EXECUTIONS_MODE=queue

# Redis connection (Railway Redis plugin, private network = no egress cost).
# RAILWAY_PRIVATE_DOMAIN resolves on the internal network; the internal Redis port is 6379.
QUEUE_BULL_REDIS_HOST=${{Redis.RAILWAY_PRIVATE_DOMAIN}}
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=${{Redis.REDISPASSWORD}}

# Let Railway's healthcheck see queue health.
QUEUE_HEALTH_CHECK_ACTIVE=true

# Keep ad-hoc "execute node/workflow" test runs from the n8n editor on the main process,
# so interactive test-runs stay snappy and don't wait on a worker slot. Optional.
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=false
